# Supabase — get these from your project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Postgres connection string (for Drizzle migrations + server-side queries)
# Settings > Database > Connection string (Transaction mode, port 6543 for pooler)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

# Supabase service role key — Settings > API > service_role (keep secret, server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (ticket QR delivery) — Gmail SMTP, free, no domain needed.
# Gmail account with 2-Step Verification > App passwords > paste here.
GMAIL_USER=your-event-address@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Future provider: Resend + verified domain (used only when Gmail vars are empty)
RESEND_API_KEY=
# RESEND_FROM=The Colosseum <tickets@yourdomain.pk>

# Public site URL (baked into QR code links)
NEXT_PUBLIC_SITE_URL=https://thecolosseumpk.vercel.app
